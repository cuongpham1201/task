{
  "name": "giaoviec",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "dev:api": "npm run start:dev -w api",
    "build:api": "npm run build -w api",
    "db:migrate": "npm run prisma:migrate -w api",
    "db:seed": "npm run prisma:seed -w api",
    "sync:hrm-dev": "node --env-file=apps/api/.env apps/api/scripts/sync-hrm-dev.mjs",
    "reminders": "node --env-file=apps/api/.env apps/api/scripts/deadline-reminders.mjs"
  }
}
