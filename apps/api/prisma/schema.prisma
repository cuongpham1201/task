// Schema — App Giao việc. Phase ORG-1: cây tổ chức + workspace + visibility.
// HRM là nguồn master cơ cấu tổ chức (org_units source=HRM). Xem
// docs/org-workspace-visibility-design.md và docs/bhl-org-structure-analysis.md.
// Task luôn thuộc đúng 1 workspace (ORG_UNIT hoặc PROJECT); personal = workspace_id null.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin // system admin (thấy tất cả — kỹ thuật)
  manager
  member

  @@map("user_role")
}

// Cây tổ chức: Công ty → Khối → Phòng/Ban (lấy tới cấp DEPARTMENT theo HRM)
enum OrgUnitType {
  company
  block // khối chức năng (theo Giám đốc) / BDH
  department // phòng/ban/kênh/trung tâm/phân xưởng

  @@map("org_unit_type")
}

// Quyền theo tổ chức
enum OrgRole {
  ceo // TGĐ / Ban Điều Hành
  block_director // Giám đốc khối
  department_manager // Trưởng phòng/ban
  viewer

  @@map("org_role")
}

enum RoleScope {
  self_only
  include_children

  @@map("role_scope")
}

enum WorkspaceType {
  org_unit // việc nội bộ phòng/ban (member suy từ org tree)
  project // dự án kiểu Asana (member thủ công)

  @@map("workspace_type")
}

enum TaskStatus {
  todo
  doing
  waiting
  submitted // chờ nghiệm thu
  returned // bị trả lại
  done
  paused

  @@map("task_status")
}

enum CompletionMode {
  self
  review_required

  @@map("completion_mode")
}

enum ReviewDecision {
  passed
  returned

  @@map("review_decision")
}

enum TaskPriority {
  low
  normal
  high
  urgent

  @@map("task_priority")
}

enum TaskSection {
  suvu
  kehoach
  hangngay
  phatsinh

  @@map("task_section")
}

enum ActivityAction {
  create
  assign
  status
  due
  priority
  progress
  comment
  complete
  subtask
  attachment
  collaborator
  review
  edit

  @@map("activity_action")
}

enum NotificationType {
  task_assigned
  comment_added
  mentioned
  due_soon
  overdue
  task_returned
  task_accepted

  @@map("notification_type")
}

enum SyncDirection {
  inbound
  outbound

  @@map("sync_direction")
}

enum PushStatus {
  pending
  sent
  ack
  error

  @@map("push_status")
}

model User {
  id          String   @id @default(uuid())
  entraId     String?  @unique @map("entra_id")
  email       String   @unique
  displayName String   @map("display_name")
  orgUnitId   String?  @map("org_unit_id") // phòng/ban chính (từ HRM)
  role        UserRole @default(member)
  jobTitle    String?  @map("job_title")
  avatarUrl   String?  @map("avatar_url")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orgUnit               OrgUnit?             @relation("OrgUnitMembers", fields: [orgUnitId], references: [id])
  orgUnitRoles          OrgUnitRole[]
  ownedWorkspaces       Workspace[]          @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMember[]    @relation("WorkspaceMemberships")
  workspaceMembersAdded WorkspaceMember[]    @relation("WorkspaceMemberAddedBy")
  createdTasks          Task[]               @relation("TaskCreator")
  assignedTasks         Task[]               @relation("TaskAssignee")
  completedTasks        Task[]               @relation("TaskCompletedBy")
  reviews               TaskReview[]         @relation("TaskReviewer")
  collaborations        TaskCollaborator[]
  watching              TaskWatcher[]
  subtasks              Subtask[]
  comments              Comment[]
  activities            Activity[]
  notifications         Notification[]
  attachments           Attachment[]
  externalMapping       ExternalUserMapping?

  @@map("users")
}

// ── Cây tổ chức (master = HRM) ───────────────────────────────────────
model OrgUnit {
  id            String      @id @default(uuid())
  code          String      @unique
  name          String
  type          OrgUnitType
  parentId      String?     @map("parent_id")
  legalEntity   String?     @map("legal_entity") // HALONG / DONGMAI / GROUP (theo HRM)
  sortOrder     Int         @default(0) @map("sort_order")
  active        Boolean     @default(true)
  source        String      @default("HRM")
  externalHrmId String?     @map("external_hrm_id")

  parent    OrgUnit?      @relation("OrgTree", fields: [parentId], references: [id])
  children  OrgUnit[]     @relation("OrgTree")
  members   User[]        @relation("OrgUnitMembers")
  roles     OrgUnitRole[]
  workspace Workspace? // workspace ORG_UNIT tương ứng (1-1)

  @@index([parentId])
  @@index([type])
  @@map("org_units")
}

model OrgUnitRole {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  orgUnitId String    @map("org_unit_id")
  role      OrgRole
  scope     RoleScope @default(self_only)
  source    String    @default("MANUAL")
  active    Boolean   @default(true)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgUnit OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgUnitId])
  @@map("org_unit_roles")
}

// ── Workspace = ranh giới visibility của task ────────────────────────
model Workspace {
  id          String        @id @default(uuid())
  type        WorkspaceType
  name        String
  orgUnitId   String?       @unique @map("org_unit_id") // set khi type=org_unit
  ownerId     String?       @map("owner_id") // set khi type=project
  description String?
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  orgUnit OrgUnit?          @relation(fields: [orgUnitId], references: [id])
  owner   User?             @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]
  tasks   Task[]

  @@index([type])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member") // owner / manager / member / viewer
  source      String   @default("MANUAL")
  addedById   String?  @map("added_by")
  addedAt     DateTime @default(now()) @map("added_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("WorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade)
  addedBy   User?     @relation("WorkspaceMemberAddedBy", fields: [addedById], references: [id])

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model Task {
  id             String         @id @default(uuid())
  title          String
  description    String         @default("")
  workspaceId    String?        @map("workspace_id") // null = việc cá nhân
  section        TaskSection?
  creatorId      String         @map("creator_id")
  assigneeId     String         @map("assignee_id")
  status         TaskStatus     @default(todo)
  completionMode CompletionMode @default(self) @map("completion_mode")
  priority       TaskPriority   @default(normal)
  startDate      DateTime?      @map("start_date") @db.Date
  dueDate        DateTime?      @map("due_date") @db.Date
  progress       Int            @default(0) @db.SmallInt
  sortOrder      Float          @default(0) @map("sort_order")
  archived       Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  completedAt    DateTime?      @map("completed_at")
  completedById  String?        @map("completed_by")

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  creator     User       @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedBy User?      @relation("TaskCompletedBy", fields: [completedById], references: [id])
  review      TaskReview?

  collaborators TaskCollaborator[]
  watchers      TaskWatcher[]
  subtasks      Subtask[]
  comments      Comment[]
  activities    Activity[]
  attachments   Attachment[]

  @@index([assigneeId])
  @@index([workspaceId, status])
  @@index([dueDate])
  @@index([status])
  @@map("tasks")
}

model TaskReview {
  id         String         @id @default(uuid())
  taskId     String         @unique @map("task_id")
  reviewerId String         @map("reviewer_id")
  decision   ReviewDecision
  note       String         @default("")
  reviewedAt DateTime       @default(now()) @map("reviewed_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation("TaskReviewer", fields: [reviewerId], references: [id])

  @@map("task_reviews")
}

model TaskCollaborator {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_collaborators")
}

model TaskWatcher {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_watchers")
}

model Subtask {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  title      String
  done       Boolean  @default(false)
  assigneeId String?  @map("assignee_id")
  sortOrder  Float    @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId], references: [id])

  @@index([taskId])
  @@map("subtasks")
}

model Comment {
  id        String    @id @default(uuid())
  taskId    String    @map("task_id")
  userId    String    @map("user_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("comments")
}

model Activity {
  id        BigInt         @id @default(autoincrement())
  taskId    String         @map("task_id")
  userId    String         @map("user_id")
  action    ActivityAction
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now()) @map("created_at")

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  notifications Notification[]

  @@index([taskId, createdAt])
  @@map("activities")
}

model Notification {
  id         BigInt           @id @default(autoincrement())
  userId     String           @map("user_id")
  type       NotificationType
  activityId BigInt?          @map("activity_id")
  taskId     String?          @map("task_id")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model Attachment {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  uploadedById String    @map("uploaded_by")
  fileName     String    @map("file_name")
  mimeType     String    @map("mime_type")
  sizeBytes    BigInt    @map("size_bytes")
  driveId      String    @map("drive_id")
  driveItemId  String    @map("drive_item_id")
  webUrl       String    @map("web_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("attachments")
}

// ── Tích hợp HRM (tối thiểu, CHƯA sync thật) ─────────────────────────
model ExternalUserMapping {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  entraObjectId String   @unique @map("entra_object_id")
  empCode       String?  @unique @map("emp_code")
  hrmEmployeeId String?  @map("hrm_employee_id")
  syncedAt      DateTime @default(now()) @map("synced_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("external_user_mappings")
}

// Ánh xạ org_unit ↔ đơn vị HRM (khối/phòng ban)
model ExternalOrgMapping {
  id          String   @id @default(uuid())
  orgUnitId   String   @unique @map("org_unit_id")
  hrmEntity   String?  @map("hrm_entity") // pháp nhân HRM
  hrmDeptCode String   @map("hrm_dept_code")
  hrmBlock    String?  @map("hrm_block")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@map("external_org_mappings")
}

model TaskKpiResult {
  id              String     @id @default(uuid())
  taskId          String     @map("task_id")
  entraObjectId   String     @map("entra_object_id")
  empCode         String?    @map("emp_code")
  dueDate         DateTime?  @map("due_date") @db.Date
  completedAt     DateTime?  @map("completed_at")
  acceptedAt      DateTime   @map("accepted_at")
  reviewerEntraId String?    @map("reviewer_entra_id")
  idempotencyKey  String     @unique @map("idempotency_key")
  pushStatus      PushStatus @default(pending) @map("push_status")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([pushStatus])
  @@map("task_kpi_results")
}

model SyncLog {
  id         String        @id @default(uuid())
  direction  SyncDirection
  entity     String
  count      Int           @default(0)
  status     String
  error      String?
  startedAt  DateTime      @map("started_at")
  finishedAt DateTime?     @map("finished_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("sync_logs")
}
