// Schema — App Giao việc. Phase ORG-1: cây tổ chức + workspace + visibility.
// HRM là nguồn master cơ cấu tổ chức (org_units source=HRM). Xem
// docs/org-workspace-visibility-design.md và docs/bhl-org-structure-analysis.md.
// Task luôn thuộc đúng 1 workspace (ORG_UNIT hoặc PROJECT); personal = workspace_id null.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin // system admin (thấy tất cả — kỹ thuật)
  manager
  member

  @@map("user_role")
}

// Cây tổ chức: Công ty → Khối → Phòng/Ban (lấy tới cấp DEPARTMENT theo HRM)
enum OrgUnitType {
  company
  block // khối chức năng (theo Giám đốc) / BDH
  department // phòng/ban/kênh/trung tâm/phân xưởng

  @@map("org_unit_type")
}

// Quyền theo tổ chức
enum OrgRole {
  ceo // TGĐ / Ban Điều Hành
  block_director // Giám đốc khối
  department_manager // Trưởng phòng/ban
  viewer

  @@map("org_role")
}

enum RoleScope {
  self_only
  include_children

  @@map("role_scope")
}

enum WorkspaceType {
  org_unit // việc nội bộ phòng/ban (member suy từ org tree)
  project // dự án kiểu Asana (member thủ công)

  @@map("workspace_type")
}

enum TaskStatus {
  todo
  doing
  waiting
  submitted // chờ nghiệm thu
  returned // bị trả lại
  done
  paused

  @@map("task_status")
}

enum CompletionMode {
  self
  review_required

  @@map("completion_mode")
}

enum ReviewDecision {
  passed
  returned

  @@map("review_decision")
}

enum TaskPriority {
  low
  normal
  high
  urgent

  @@map("task_priority")
}


enum ActivityAction {
  create
  assign
  status
  due
  priority
  progress
  comment
  complete
  subtask
  attachment
  collaborator
  review
  edit

  @@map("activity_action")
}

enum NotificationType {
  task_assigned
  comment_added
  mentioned
  due_soon
  overdue
  task_returned
  task_accepted
  // P1-3 Reminder Engine
  task_not_started
  review_waiting // task chờ nghiệm thu quá lâu → nhắc reviewer
  returned_pending // bị trả lại chưa gửi lại → nhắc assignee
  action_due_soon
  action_overdue
  action_empty // action tạo lâu nhưng chưa có task

  @@map("notification_type")
}

enum SyncDirection {
  inbound
  outbound

  @@map("sync_direction")
}

enum PushStatus {
  pending
  sent
  ack
  error

  @@map("push_status")
}

// ── Action Log (cam kết/mục tiêu quản lý, thuộc org_unit) ──
// A2 delta (freeze §10): enum status chốt draft/in_progress/on_hold/at_risk/done/cancelled.
enum ActionStatus {
  draft
  in_progress
  on_hold
  at_risk
  done
  cancelled

  @@map("action_status")
}

enum ProgressMode {
  manual
  auto_from_tasks

  @@map("progress_mode")
}

// A2 delta (freeze §8): Action Update = "Nhật ký điều hành" — 7 loại.
enum ActionUpdateType {
  progress
  issue
  risk
  recommendation
  decision
  result
  note

  @@map("action_update_type")
}

model User {
  id                 String    @id @default(uuid())
  entraId            String?   @unique @map("entra_id")
  email              String    @unique
  displayName        String    @map("display_name")
  orgUnitId          String?   @map("org_unit_id") // phòng/ban chính (từ HRM)
  role               UserRole  @default(member)
  jobTitle           String?   @map("job_title")
  avatarUrl          String?   @map("avatar_url")
  active             Boolean   @default(true)
  // ── FEATURE-001: Local login (App sở hữu; HRM KHÔNG đụng các field này) ──
  username           String?   @unique
  passwordHash       String?   @map("password_hash") // bcrypt — KHÔNG BAO GIỜ trả qua API
  localLoginEnabled  Boolean   @default(false) @map("local_login_enabled")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until")
  lastLoginAt        DateTime? @map("last_login_at")
  passwordChangedAt  DateTime? @map("password_changed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  orgUnit               OrgUnit?              @relation("OrgUnitMembers", fields: [orgUnitId], references: [id])
  orgUnitRoles          OrgUnitRole[]
  ownedWorkspaces       Workspace[]           @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMember[]     @relation("WorkspaceMemberships")
  workspaceMembersAdded WorkspaceMember[]     @relation("WorkspaceMemberAddedBy")
  createdTasks          Task[]                @relation("TaskCreator")
  assignedTasks         Task[]                @relation("TaskAssignee")
  completedTasks        Task[]                @relation("TaskCompletedBy")
  reviews               TaskReview[]          @relation("TaskReviewer")
  collaborations        TaskCollaborator[]
  watching              TaskWatcher[]
  subtasks              Subtask[]
  comments              Comment[]
  activities            Activity[]
  notifications         Notification[]
  attachments           Attachment[]
  externalMapping       ExternalUserMapping?
  ownedActions          Action[]              @relation("ActionOwner")
  createdActions        Action[]              @relation("ActionCreatedBy")
  actionUpdates         ActionUpdate[]        @relation("ActionUpdateAuthor")
  reviewedKpiResults    TaskKpiResult[]       @relation("KpiResultReviewer")
  workLogs              TaskWorkLog[]         @relation("WorkLogAuthor")
  adminActionsDone      AdminAuditLog[]       @relation("AuditActor")
  adminActionsReceived  AdminAuditLog[]       @relation("AuditTarget")
  orgRolesGranted       OrgUnitRole[]         @relation("OrgRoleCreatedBy")
  tasksToReview         Task[]                @relation("TaskDesignatedReviewer")
  reminderSettingsEdits ReminderSetting[]     @relation("ReminderSettingUpdatedBy")
  importBatches         ExternalImportBatch[] @relation("ImportBatchBy")

  @@map("users")
}

// ── Cây tổ chức (master = HRM) ───────────────────────────────────────
model OrgUnit {
  id            String      @id @default(uuid())
  code          String      @unique
  name          String
  type          OrgUnitType
  parentId      String?     @map("parent_id")
  legalEntity   String?     @map("legal_entity") // HALONG / DONGMAI / GROUP (theo HRM)
  sortOrder     Int         @default(0) @map("sort_order")
  active        Boolean     @default(true)
  source        String      @default("HRM")
  externalHrmId String?     @map("external_hrm_id")

  parent         OrgUnit?        @relation("OrgTree", fields: [parentId], references: [id])
  children       OrgUnit[]       @relation("OrgTree")
  members        User[]          @relation("OrgUnitMembers")
  roles          OrgUnitRole[]
  workspace      Workspace? // workspace ORG_UNIT tương ứng (1-1)
  tasks          Task[]          @relation("TaskOrgUnit")
  actions        Action[]        @relation("ActionOrgUnit")
  kpiDefinitions KpiDefinition[] @relation("KpiDefOrgUnit")

  @@index([parentId])
  @@index([type])
  @@map("org_units")
}

model OrgUnitRole {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  orgUnitId   String    @map("org_unit_id")
  role        OrgRole
  scope       RoleScope @default(self_only)
  // MANUAL (admin UI) | HRM_SYNC (script sở hữu) | MANUAL_TEST (seed dev) | SEED
  source      String    @default("MANUAL")
  active      Boolean   @default(true)
  // FEATURE-003: unique nghiệp vụ (userId+orgUnitId+role khi active) enforce Ở APP-LEVEL
  // trong transaction — không partial-unique DB (prisma không model được → drift).
  // Record inactive giữ làm lịch sử; tạo trùng tuple inactive → tái kích hoạt record cũ.
  note        String?   @db.VarChar(300)
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgUnit   OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("OrgRoleCreatedBy", fields: [createdById], references: [id])

  @@index([userId])
  @@index([orgUnitId])
  @@index([userId, active])
  @@index([orgUnitId, active])
  @@index([source])
  @@map("org_unit_roles")
}

// ── Workspace = ranh giới visibility của task ────────────────────────
model Workspace {
  id          String        @id @default(uuid())
  type        WorkspaceType
  name        String
  orgUnitId   String?       @unique @map("org_unit_id") // set khi type=org_unit
  ownerId     String?       @map("owner_id") // set khi type=project
  description String?
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  orgUnit OrgUnit?          @relation(fields: [orgUnitId], references: [id])
  owner   User?             @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]
  tasks   Task[]

  @@index([type])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member") // owner / manager / member / viewer
  source      String   @default("MANUAL")
  addedById   String?  @map("added_by")
  addedAt     DateTime @default(now()) @map("added_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("WorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade)
  addedBy   User?     @relation("WorkspaceMemberAddedBy", fields: [addedById], references: [id])

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model Task {
  id              String         @id @default(uuid())
  title           String
  description     String         @default("")
  expectedOutput  String         @default("") @map("expected_output") // Kết quả cần đạt (nghiệm thu đối chiếu)
  workspaceId     String?        @map("workspace_id") // null = việc cá nhân (DEPRECATED sau A2 — thay bằng org_unit_id/project_id)
  // ── A1: các chiều tường minh ──
  orgUnitId       String?        @map("org_unit_id") // đơn vị chịu trách nhiệm (bắt buộc ở tầng app với task nghiệp vụ)
  projectId       String?        @map("project_id") // P1: = workspace.id của workspace type=project (không đặt FK để dễ tách bảng projects sau)
  actionId        String?        @map("action_id") // thuộc Action nào (nullable)
  sectionId       String?        @map("section_id") // "Section" (nhóm sắp xếp) — danh sách chung do admin quản (Section table). Gộp "Loại việc" cũ vào đây (bỏ enum TaskSection).
  creatorId       String         @map("creator_id")
  assigneeId      String         @map("assignee_id")
  status          TaskStatus     @default(todo)
  completionMode  CompletionMode @default(self) @map("completion_mode") // DEPRECATED — dùng reviewRequired
  reviewRequired  Boolean        @default(false) @map("review_required")
  // B (13/07): task tạo bằng "Thêm nhanh" = NHÁP — chỉ người tạo thấy, sửa KHÔNG bắn
  // thông báo; bấm "Bắt đầu giao" → isDraft=false + bắn thông báo GỘP 1 lần.
  isDraft         Boolean        @default(false) @map("is_draft")
  // P0-2 (12/07/2026): người nghiệm thu CHỈ ĐỊNH — bắt buộc khi reviewRequired=true.
  // 1 reviewer (không bảng quan hệ) vì TaskReview là quyết định đơn 1-1.
  // Task cũ backfill reviewer = creator (đúng người duyệt mặc định của rule cũ).
  reviewerId      String?        @map("reviewer_id")
  priority        TaskPriority   @default(normal)
  startDate       DateTime?      @map("start_date") @db.Date
  dueDate         DateTime?      @map("due_date") @db.Date
  progress        Int            @default(0) @db.SmallInt
  sortOrder       Float          @default(0) @map("sort_order")
  archived        Boolean        @default(false)
  // ── A1: KPI evidence (App KHÔNG tính điểm cuối — chỉ mapping/evidence) ──
  isScorable      Boolean        @default(false) @map("is_scorable")
  kpiDefinitionId String?        @map("kpi_definition_id")
  kpiWeight       Float?         @map("kpi_weight")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  completedAt     DateTime?      @map("completed_at")
  acceptedAt      DateTime?      @map("accepted_at") // thời điểm nghiệm thu Đạt
  completedById   String?        @map("completed_by")

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id])
  orgUnit       OrgUnit?       @relation("TaskOrgUnit", fields: [orgUnitId], references: [id])
  action        Action?        @relation(fields: [actionId], references: [id])
  sectionRef    Section?       @relation(fields: [sectionId], references: [id])
  reviewer      User?          @relation("TaskDesignatedReviewer", fields: [reviewerId], references: [id])
  kpiDefinition KpiDefinition? @relation(fields: [kpiDefinitionId], references: [id])
  creator       User           @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee      User           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedBy   User?          @relation("TaskCompletedBy", fields: [completedById], references: [id])
  review        TaskReview?

  collaborators TaskCollaborator[]
  watchers      TaskWatcher[]
  subtasks      Subtask[]
  comments      Comment[]
  activities    Activity[]
  attachments   Attachment[]
  kpiResults    TaskKpiResult[]
  workLogs      TaskWorkLog[]

  @@index([assigneeId])
  @@index([reviewerId])
  @@index([workspaceId, status])
  @@index([orgUnitId, status])
  @@index([projectId, status])
  @@index([actionId])
  @@index([dueDate])
  @@index([status])
  @@index([sectionId])
  @@map("tasks")
}

// "Section" (nhóm sắp xếp) — danh sách CHUNG toàn hệ thống, CHỈ admin quản.
// Trục phân loại duy nhất của task (đã gộp "Loại việc"/enum cũ vào đây). Task.sectionId trỏ tới đây (tùy chọn).
model Section {
  id           String   @id @default(uuid())
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  active       Boolean  @default(true)
  // Rule tự động: task chuyển sang done → gán vào section này. Tối đa 1 section active
  // được đánh dấu (enforce app-level khi set). Mở lại task done → gỡ khỏi section này.
  isDoneBucket Boolean  @default(false) @map("is_done_bucket")
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@index([active, sortOrder])
  @@map("sections")
}

model TaskReview {
  id         String         @id @default(uuid())
  taskId     String         @unique @map("task_id")
  reviewerId String         @map("reviewer_id")
  decision   ReviewDecision
  note       String         @default("")
  reviewedAt DateTime       @default(now()) @map("reviewed_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation("TaskReviewer", fields: [reviewerId], references: [id])

  @@map("task_reviews")
}

model TaskCollaborator {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_collaborators")
}

model TaskWatcher {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_watchers")
}

model Subtask {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  title      String
  done       Boolean  @default(false)
  assigneeId String?  @map("assignee_id")
  sortOrder  Float    @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId], references: [id])

  @@index([taskId])
  @@map("subtasks")
}

model Comment {
  id        String    @id @default(uuid())
  taskId    String    @map("task_id")
  userId    String    @map("user_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("comments")
}

model Activity {
  id        BigInt         @id @default(autoincrement())
  taskId    String         @map("task_id")
  userId    String         @map("user_id")
  action    ActivityAction
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now()) @map("created_at")

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  notifications Notification[]

  @@index([taskId, createdAt])
  @@map("activities")
}

model Notification {
  id         BigInt           @id @default(autoincrement())
  userId     String           @map("user_id")
  type       NotificationType
  activityId BigInt?          @map("activity_id")
  taskId     String?          @map("task_id")
  // P1-3: reminder có thể trỏ Action (deep-link) + payload nội dung cụ thể
  // ({message, stage, days} — "Công việc đã quá hạn 3 ngày" thay vì text chung chung)
  actionId   String?          @map("action_id")
  payload    Json?
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  action   Action?   @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ── P1-3 Reminder Engine: dedupe + audit log ─────────────────────────
// MỖI (rule, entity, người nhận, stage[, mốc hạn]) chỉ gửi ĐÚNG 1 lần —
// dedupeKey UNIQUE; chạy lại/retry/manual+cron/2 instance đều không trùng.
// dueDay nằm trong dedupeKey của rule theo deadline → đổi deadline tính lại đúng.
model ReminderDelivery {
  id          String   @id @default(uuid())
  ruleKey     String   @map("rule_key") // TASK_DUE_SOON | TASK_OVERDUE | ...
  entityType  String   @map("entity_type") // task | action
  entityId    String   @map("entity_id")
  recipientId String   @map("recipient_id")
  stageKey    String   @map("stage_key") // D3/D1/D0/OD1/OD3/OD7/OD14.../NS2/W1/R1/AE2...
  dedupeKey   String   @unique @map("dedupe_key")
  channel     String   @default("inapp")
  status      String   @default("sent")
  runId       String?  @map("run_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([recipientId, createdAt])
  @@map("reminder_deliveries")
}

// P1-4: override cấu hình reminder từ Admin UI — 1 dòng JSON (key='engine').
// Ưu tiên: DB override > env > default trong code. Không lưu secret.
model ReminderSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  updatedBy User? @relation("ReminderSettingUpdatedBy", fields: [updatedById], references: [id])

  @@map("reminder_settings")
}

model ReminderRun {
  id         String    @id @default(uuid())
  dryRun     Boolean   @default(false) @map("dry_run")
  trigger    String    @default("cron") // cron | manual
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  scanned    Int       @default(0)
  candidates Int       @default(0)
  delivered  Int       @default(0)
  skipped    Int       @default(0)
  duplicate  Int       @default(0)
  failed     Int       @default(0)
  durationMs Int       @default(0) @map("duration_ms")
  error      String?

  @@index([startedAt])
  @@map("reminder_runs")
}

model Attachment {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  uploadedById String    @map("uploaded_by")
  fileName     String    @map("file_name")
  mimeType     String    @map("mime_type")
  sizeBytes    BigInt    @map("size_bytes")
  // SharePoint (để sau); dev dùng storageKey (local disk). Nới nullable.
  driveId      String?   @map("drive_id")
  driveItemId  String?   @map("drive_item_id")
  webUrl       String?   @map("web_url")
  storageKey   String?   @map("storage_key")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("attachments")
}

// ── Tích hợp HRM (tối thiểu, CHƯA sync thật) ─────────────────────────
model ExternalUserMapping {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  entraObjectId String   @unique @map("entra_object_id")
  empCode       String?  @unique @map("emp_code")
  hrmEmployeeId String?  @map("hrm_employee_id")
  syncedAt      DateTime @default(now()) @map("synced_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("external_user_mappings")
}

// Ánh xạ org_unit ↔ đơn vị HRM (khối/phòng ban)
model ExternalOrgMapping {
  id          String   @id @default(uuid())
  orgUnitId   String   @unique @map("org_unit_id")
  hrmEntity   String?  @map("hrm_entity") // pháp nhân HRM
  hrmDeptCode String   @map("hrm_dept_code")
  hrmBlock    String?  @map("hrm_block")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@map("external_org_mappings")
}

// ── P1-6: Import từ nguồn ngoài (Asana JSON) ─────────────────────────
// Idempotency GENERIC theo (source, entityType, externalId). KHÔNG dedupe bằng
// title/date/assignee. Import lại: đã có mapping → SKIP, chưa có → CREATE.
// KHÔNG thêm cột externalRef vào Task (bảng mapping đủ + đa nguồn — freeze P).
model ExternalEntityMapping {
  id              String    @id @default(uuid())
  source          String // 'asana'
  entityType      String    @map("entity_type") // task | subtask | project | user
  externalId      String    @map("external_id") // Asana gid
  internalId      String    @map("internal_id") // id trong App (task/workspace/user)
  importBatchId   String?   @map("import_batch_id")
  sourceUrl       String?   @map("source_url") // permalink_url (metadata, KHÔNG fetch)
  sourceCreatedAt DateTime? @map("source_created_at") // created_at gốc bên Asana
  payloadHash     String?   @map("payload_hash")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  batch ExternalImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@unique([source, entityType, externalId])
  @@index([importBatchId])
  @@index([internalId])
  @@map("external_entity_mappings")
}

// P1-6: 1 lần chạy import = 1 batch. Lưu normalizedJson (đã flatten+dedupe+sanitize,
// GIỚI HẠN kích thước) để preview/execute stateless (multi-worker), KHÔNG lưu raw JSON gốc.
model ExternalImportBatch {
  id                String    @id @default(uuid())
  source            String    @default("asana")
  status            String    @default("parsed") // parsed | ready | running | completed | partial | failed
  sourceProjectId   String?   @map("source_project_id") // Asana project gid nguồn
  sourceProjectName String?   @map("source_project_name")
  targetProjectId   String?   @map("target_project_id") // workspace.id đích
  defaultOrgUnitId  String?   @map("default_org_unit_id")
  importedById      String    @map("imported_by_id")
  mappingJson       Json?     @map("mapping_json") // cấu hình field/user/section mapping
  normalizedJson    Json?     @map("normalized_json") // dữ liệu chuẩn hoá (capped)
  payloadHash       String?   @map("payload_hash")
  totalItems        Int       @default(0) @map("total_items")
  createdCount      Int       @default(0) @map("created_count")
  skippedCount      Int       @default(0) @map("skipped_count")
  failedCount       Int       @default(0) @map("failed_count")
  warningCount      Int       @default(0) @map("warning_count")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  errorSummary      String?   @map("error_summary")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  importedBy User                    @relation("ImportBatchBy", fields: [importedById], references: [id])
  mappings   ExternalEntityMapping[]

  @@index([importedById, createdAt])
  @@index([status])
  @@map("external_import_batches")
}

model TaskKpiResult {
  id              String     @id @default(uuid())
  taskId          String     @map("task_id")
  entraObjectId   String     @map("entra_object_id")
  empCode         String?    @map("emp_code")
  dueDate         DateTime?  @map("due_date") @db.Date
  completedAt     DateTime?  @map("completed_at")
  acceptedAt      DateTime   @map("accepted_at")
  reviewerEntraId String?    @map("reviewer_entra_id")
  idempotencyKey  String     @unique @map("idempotency_key")
  pushStatus      PushStatus @default(pending) @map("push_status")
  createdAt       DateTime   @default(now()) @map("created_at")
  // ── A1: evidence bổ sung (App sinh, HRM tiêu thụ — App KHÔNG tính điểm cuối) ──
  orgUnitId       String?    @map("org_unit_id")
  kpiDefinitionId String?    @map("kpi_definition_id")
  kpiWeight       Float?     @map("kpi_weight")
  reviewResult    String?    @map("review_result") // accepted | returned
  onTime          Boolean?   @map("on_time")
  evidenceNote    String?    @map("evidence_note")
  reviewedById    String?    @map("reviewed_by")
  reviewedAt      DateTime?  @map("reviewed_at")
  externalHrmId   String?    @map("external_hrm_id") // id bên HRM sau khi push

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("KpiResultReviewer", fields: [reviewedById], references: [id])

  @@index([pushStatus])
  @@index([taskId])
  @@map("task_kpi_results")
}

// Item 12: Nhật ký thực hiện task (append-only) — khác comment (thảo luận) & activity (audit).
model TaskWorkLog {
  id            String   @id @default(uuid())
  taskId        String   @map("task_id")
  authorId      String   @map("author_id")
  content       String
  progressValue Int?     @map("progress_value") @db.SmallInt
  createdAt     DateTime @default(now()) @map("created_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("WorkLogAuthor", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_work_logs")
}

// Teams Activity Feed delivery log — idempotency + trạng thái gửi + retry/error per recipient.
// KHÔNG dùng notifications (không lưu attempt/error/entra) hay sync_logs (không có unique per-recipient key).
model TeamsActivityDelivery {
  id             String    @id @default(uuid())
  eventKey       String    @unique @map("event_key") // <activityType>:<targetId>:<recipientId>:<suffix>
  recipientId    String    @map("recipient_user_id")
  recipientEntra String?   @map("recipient_entra_id")
  activityType   String    @map("activity_type")
  targetType     String    @map("target_type") // task | project
  targetId       String    @map("target_id")
  status         String // sent | skipped_missing_entra_id | error | disabled
  attemptCount   Int       @default(0) @map("attempt_count")
  lastError      String?   @map("last_error")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([recipientId, createdAt])
  @@map("teams_activity_deliveries")
}

// FEATURE-001: Nhật ký quản trị (provision/reset/lock/role...) — KHÔNG lưu password.
model AdminAuditLog {
  id           String   @id @default(uuid())
  actorId      String   @map("actor_id")
  targetUserId String?  @map("target_user_id")
  action       String // provision_local | reset_password | set_access | set_role | hrm_sync_run | link_entra
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User  @relation("AuditActor", fields: [actorId], references: [id])
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId, createdAt])
  @@map("admin_audit_logs")
}

model SyncLog {
  id         String        @id @default(uuid())
  direction  SyncDirection
  entity     String
  count      Int           @default(0)
  status     String
  error      String?
  startedAt  DateTime      @map("started_at")
  finishedAt DateTime?     @map("finished_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("sync_logs")
}

// ── A1: Action = cam kết/mục tiêu quản lý, thuộc 1 org_unit (KHÔNG thuộc project).
// Action là container; KHÔNG nghiệm thu, KHÔNG tính KPI trực tiếp. Chỉ Task mới review/KPI.
model Action {
  id           String       @id @default(uuid())
  title        String
  description  String       @default("")
  orgUnitId    String       @map("org_unit_id") // đơn vị chịu trách nhiệm (bắt buộc)
  projectId    String?      @map("project_id") // A2 delta: liên kết 1 project (nullable, KHÔNG phải ACL — freeze §12a)
  ownerId      String       @map("owner_id") // người chịu trách nhiệm báo cáo (KHÔNG phải assignee)
  deadline     DateTime?    @db.Date
  status       ActionStatus @default(draft)
  priority     TaskPriority @default(normal)
  progressMode ProgressMode @default(manual) @map("progress_mode")
  progress     Int          @default(0) @db.SmallInt
  period       String? // vd '2026-07'
  createdById  String       @map("created_by")
  archived     Boolean      @default(false)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  orgUnit   OrgUnit        @relation("ActionOrgUnit", fields: [orgUnitId], references: [id])
  owner     User           @relation("ActionOwner", fields: [ownerId], references: [id])
  createdBy User           @relation("ActionCreatedBy", fields: [createdById], references: [id])
  tasks     Task[]
  updates   ActionUpdate[]

  reminderNotifications Notification[]

  @@index([orgUnitId, period])
  @@index([projectId])
  @@index([status])
  @@map("actions")
}

// A2 delta (freeze §8): Nhật ký điều hành — APPEND-ONLY (không update, không delete).
model ActionUpdate {
  id            String           @id @default(uuid())
  actionId      String           @map("action_id")
  authorId      String           @map("author_id")
  type          ActionUpdateType @default(progress)
  content       String
  progressValue Int?             @map("progress_value") @db.SmallInt // ảnh chụp tiến độ tại thời điểm cập nhật
  statusFrom    ActionStatus?    @map("status_from")
  statusTo      ActionStatus?    @map("status_to")
  createdAt     DateTime         @default(now()) @map("created_at")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  author User   @relation("ActionUpdateAuthor", fields: [authorId], references: [id])

  @@index([actionId, createdAt])
  @@map("action_updates")
}

// ── A1: KPI definition = cache read-only từ HRM (source=HRM) hoặc mẫu local (source=local_seed).
// App KHÔNG là master định nghĩa KPI; đây chỉ để Task ánh xạ + hiển thị. Sync thật ở A6.
model KpiDefinition {
  id            String   @id @default(uuid())
  externalHrmId String?  @unique @map("external_hrm_id")
  orgUnitId     String?  @map("org_unit_id")
  name          String
  unit          String? // đơn vị đo
  defaultWeight Float?   @map("default_weight")
  periodType    String?  @map("period_type")
  active        Boolean  @default(true)
  source        String   @default("HRM") // HRM | local_seed
  syncedAt      DateTime @default(now()) @map("synced_at")

  orgUnit OrgUnit? @relation("KpiDefOrgUnit", fields: [orgUnitId], references: [id])
  tasks   Task[]

  @@index([orgUnitId])
  @@map("kpi_definitions")
}
