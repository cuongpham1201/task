# PostgreSQL — copy thành .env và điền thông tin thật
DATABASE_URL="postgresql://giaoviec:giaoviec@localhost:5432/giaoviec?schema=public"
PORT=3000

# Dev không có PostgreSQL/Docker? Dùng Postgres cục bộ của Prisma:
#   cd apps/api && npx prisma dev
# rồi lấy DATABASE_URL nó in ra và THÊM "&pgbouncer=true" vào cuối
# (server của prisma dev là connection pooler, cần tắt prepared statements).

# ── SSO Azure AD (M365) — luồng code phía server, giống app văn bản/phê duyệt ──
# Đủ 3 giá trị AZURE_AD_* → BẬT SSO thật. Thiếu secret → CHẾ ĐỘ DEV
# (không đăng nhập; nhận danh tính qua header x-dev-user-email).
AZURE_AD_TENANT_ID=""
AZURE_AD_CLIENT_ID=""            # Application (client) ID của app "giaoviec"
AZURE_AD_CLIENT_SECRET=""        # Client secret (Certificates & secrets)

AUTH_REDIRECT_URI="http://localhost:3001/api/v1/auth/callback"
WEB_ORIGIN="http://localhost:5173"
ALLOWED_EMAIL_DOMAIN="biahalong.com"
SESSION_SECRET=""                # openssl rand -base64 32

# Dev-only: /me phân giải theo email này khi CHƯA bật SSO (khớp user đã seed).
DEV_USER_EMAIL="cuongpx@biahalong.com"

# ── Microsoft Teams (Activity Feed + deep link) ──
# Bật gửi Teams Activity Feed (mặc định false — thiếu config service tự skip an toàn)
TEAMS_ACTIVITY_ENABLED=false
# Teams App ID = manifest id trong teams/manifest.json (cố định cho Giao việc)
TEAMS_APP_ID=8ff868b3-844b-4006-b932-db7db82d9f05
# Catalog App ID sau khi admin publish vào tenant catalog (Teams Admin Center)
TEAMS_CATALOG_APP_ID=
# Base URL app (deep link fallback)
TASK_APP_BASE_URL=https://task.biahalong.com
# Graph app-only dùng lại AZURE_AD_TENANT_ID / AZURE_AD_CLIENT_ID / AZURE_AD_CLIENT_SECRET ở trên
# (cần thêm Application permission TeamsActivity.Send + admin consent — xem docs/teams-app-and-activity-guide.md)
